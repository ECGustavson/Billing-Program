# ── QuickBooks Online API Credentials ─────────────────────────────────────────
# Rename this file to ".env" and place it in the same folder as the script.
# Never commit .env to version control — add it to your .gitignore.
# Obtain these values from https://developer.intuit.com (your app's Keys & OAuth page).

# OAuth 2.0 Client credentials
QBO_CLIENT_ID=[REPLACE_WITH_YOUR_CLIENT_ID]
QBO_CLIENT_SECRET=[REPLACE_WITH_YOUR_CLIENT_SECRET]

# Refresh token obtained after completing the OAuth 2.0 authorization flow.
# This rotates periodically — the script will print the new value if it changes.
QBO_REFRESH_TOKEN=[REPLACE_WITH_YOUR_REFRESH_TOKEN]

# Company/Realm ID — found in the URL when logged into QBO:
#   https://app.qbo.intuit.com/app/homepage?realmId=XXXXXXXXXX
QBO_REALM_ID=[REPLACE_WITH_YOUR_REALM_ID]

# Environment: "production" or "sandbox"
QBO_ENVIRONMENT=sandbox